# .env.example — copy to .env and fill in real values. .env is gitignored.
#
# The drone_tools package reads environment variables directly (no dotenv loader is
# bundled). Either export these in your shell, or source this file before running
# the tools:
#   set -a && source .env && set +a

# ---------------------------------------------------------------------------
# OpenAI — required by image-generation and vision tools
# ---------------------------------------------------------------------------
# Used by:
#   - drone-image-query     (drone_tools/image_query.py)
#   - drone-describe-image  (drone_tools/drone_description.py)
OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# kismet-queuer — see kismet-queuer/config/config.ini.example for the
# canonical config format. These are only used if you choose to template the
# INI file from environment variables in your own wrapper script.
# ---------------------------------------------------------------------------
# KISMET_HOST=127.0.0.1
# KISMET_PORT=2501
# KISMET_API_KEY=
# RABBITMQ_HOST=rabbitmq.local
# RABBITMQ_PORT=5672
# RABBITMQ_USER=kismet
# RABBITMQ_PASSWORD=
# RABBITMQ_EXCHANGE=kismet
