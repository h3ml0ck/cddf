---
# Example credentials file for use with Ansible Vault
#
# To use:
# 1. Copy this file to credentials.yml
# 2. Edit with your actual credentials
# 3. Encrypt with: ansible-vault encrypt vars/credentials.yml
# 4. Reference in playbook with: vars_files: - vars/credentials.yml
# 5. Run playbook with: ansible-playbook playbook.yml --ask-vault-pass

# Kismet authentication (use api_key OR username/password)
kismet_queuer_kismet_api_key: "your-kismet-api-key-here"
# kismet_queuer_kismet_username: "admin"
# kismet_queuer_kismet_password: "kismet-password"

# RabbitMQ credentials
kismet_queuer_rabbitmq_username: "kismet_user"
kismet_queuer_rabbitmq_password: "your-secure-rabbitmq-password"
